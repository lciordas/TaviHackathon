ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
CORS_ORIGINS=["http://localhost:3000"]

# Google Places API (new). Required for /discovery/run.
# Get one from console.cloud.google.com → enable "Places API (New)".
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACES_DEFAULT_RADIUS_M=32186  # ~20 miles

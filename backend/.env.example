# Anthropic — required.
# Used for intake field extraction, vendor outreach drafting, and vendor persona simulation.
# Get one: https://console.anthropic.com → API keys → Create Key.
ANTHROPIC_API_KEY=sk-ant-...

# Anthropic model — optional. Defaults to claude-sonnet-4-6.
# Override if your key doesn't have Sonnet 4.6 access.
ANTHROPIC_MODEL=claude-sonnet-4-6

# Google Places API (new) — required.
# Used for address autocomplete (intake) and nearby vendor search (discovery).
# Get one: https://console.cloud.google.com → create project → enable "Places API (New)" → Credentials → Create API key.
# IMPORTANT: enable the *new* Places API, not the legacy one — they're separate SKUs.
GOOGLE_PLACES_API_KEY=

# Discovery search radius in meters — optional. Defaults to ~20 miles.
GOOGLE_PLACES_DEFAULT_RADIUS_M=32186

# CORS allow-list for the FastAPI backend — optional. Keep localhost:3000 for local dev.
CORS_ORIGINS=["http://localhost:3000"]
